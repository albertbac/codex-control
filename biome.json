{
  "$schema": "https://biomejs.dev/schemas/2.0.5/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "vite.config.ts",
      "apps/desktop/src/**/*.ts",
      "apps/desktop/src/**/*.tsx",
      "apps/desktop/vite.config.ts"
    ]
  }
}
